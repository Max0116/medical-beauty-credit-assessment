{
  "name": "medical-beauty-credit-assessment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api:proxy": "node aliyun-api/server.js",
    "build": "vite build",
    "build:aliyun": "VITE_ASSESSMENT_API_URL=/api VITE_ASSESSMENT_API_KEY= VITE_ASSESSMENT_API_TIMEOUT_MS=8000 VITE_DEEP_VERIFICATION_HIGH_LIMIT=50000 vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "verify:release": "npm run build:aliyun && npm run verify:dist",
    "verify:dist": "node scripts/verify-dist-no-secrets.mjs",
    "release:aliyun": "npm run verify:release && node scripts/build-aliyun-release.mjs",
    "health:aliyun": "node scripts/check-aliyun-health.mjs",
    "smoke:aliyun": "node scripts/smoke-aliyun-pr22.mjs",
    "qr:aliyun": "node scripts/generate-aliyun-qr.mjs",
    "backup:supabase": "node scripts/backup-supabase.mjs",
    "db:migrate:aliyun": "node scripts/apply-aliyun-postgres-migration.mjs",
    "db:migrate:supabase-to-aliyun": "node scripts/migrate-supabase-to-aliyun-rds.mjs",
    "storage:migrate:supabase-to-oss": "node scripts/migrate-supabase-evidence-to-aliyun-oss.mjs",
    "migration:verify:aliyun": "node scripts/verify-aliyun-migration.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "ali-oss": "^6.23.0",
    "busboy": "^1.6.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.10"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "qrcode": "^1.5.4",
    "vitest": "^3.2.4"
  }
}
