server {
  listen 80;
  server_name credit.xxx.com;

  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name credit.xxx.com;

  # Replace with the certificate paths managed by Aliyun SSL, BT panel, or IT.
  ssl_certificate /etc/nginx/ssl/credit.xxx.com/fullchain.pem;
  ssl_certificate_key /etc/nginx/ssl/credit.xxx.com/privkey.pem;

  ssl_session_timeout 10m;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;

  root /var/www/medical-credit/current;
  index index.html;

  client_max_body_size 12m;

  location /api/ {
    proxy_pass http://127.0.0.1:8787/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 10s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}

