#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   RELEASE_ARCHIVE=/tmp/medical-credit-assessment-aliyun-xxx.tar.gz \
#   RELEASE_SHA256=/tmp/medical-credit-assessment-aliyun-xxx.tar.gz.sha256 \
#   sudo -E bash ops/aliyun/stage-release.sh.example
#
# Purpose:
# - Safely stage a release on an existing BT/aaPanel server.
# - Creates only versioned release directories under approved medical-credit paths.
# - Does not switch current symlinks.
# - Does not overwrite the current BT site root index.html/assets.
# - Does not edit Nginx, systemd, PM2, databases, or .env.
# - Does not restart or reload anything.

RELEASE_ARCHIVE="${RELEASE_ARCHIVE:-}"
RELEASE_SHA256="${RELEASE_SHA256:-}"
H5_ROOT="${H5_ROOT:-/www/wwwroot/medical-credit-assessment}"
API_ROOT="${API_ROOT:-/www/wwwroot/medical-credit-api}"
WORK_ROOT="${WORK_ROOT:-/www/wwwroot/medical-credit-deploy-work}"

if [[ -z "$RELEASE_ARCHIVE" || ! -f "$RELEASE_ARCHIVE" ]]; then
  echo "RELEASE_ARCHIVE is required and must point to an existing .tar.gz file." >&2
  exit 1
fi

if [[ -n "$RELEASE_SHA256" ]]; then
  if [[ ! -f "$RELEASE_SHA256" ]]; then
    echo "RELEASE_SHA256 was provided but file does not exist." >&2
    exit 1
  fi
  (cd "$(dirname "$RELEASE_ARCHIVE")" && sha256sum -c "$RELEASE_SHA256")
fi

case "$H5_ROOT" in
  /var/www/medical-credit|/www/wwwroot/medical-credit-assessment) ;;
  *)
    echo "Refusing unexpected H5_ROOT: $H5_ROOT" >&2
    echo "Set H5_ROOT only to an agreed independent medical-credit directory." >&2
    exit 1
    ;;
esac

case "$API_ROOT" in
  /var/www/medical-credit-api|/www/wwwroot/medical-credit-api) ;;
  *)
    echo "Refusing unexpected API_ROOT: $API_ROOT" >&2
    echo "Set API_ROOT only to an agreed independent medical-credit-api directory." >&2
    exit 1
    ;;
esac

case "$WORK_ROOT" in
  /var/www/medical-credit-deploy-work|/www/wwwroot/medical-credit-deploy-work) ;;
  *)
    echo "Refusing unexpected WORK_ROOT: $WORK_ROOT" >&2
    echo "Set WORK_ROOT only to an agreed independent medical-credit work directory." >&2
    exit 1
    ;;
esac

mkdir -p "$WORK_ROOT" "$H5_ROOT/releases" "$API_ROOT/releases"

release_name="$(basename "$RELEASE_ARCHIVE" .tar.gz)"
extract_dir="$WORK_ROOT/$release_name"
h5_release="$H5_ROOT/releases/$release_name"
api_release="$API_ROOT/releases/$release_name"

if [[ -e "$extract_dir" || -e "$h5_release" || -e "$api_release" ]]; then
  echo "Release staging target already exists. Refusing to overwrite: $release_name" >&2
  exit 1
fi

mkdir -p "$extract_dir"
tar -xzf "$RELEASE_ARCHIVE" -C "$extract_dir" --strip-components=1

if [[ ! -d "$extract_dir/h5" || ! -d "$extract_dir/api" ]]; then
  echo "Release archive must contain h5/ and api/ directories." >&2
  exit 1
fi

mkdir -p "$h5_release" "$api_release"
cp -R "$extract_dir/h5/." "$h5_release/"
cp -R "$extract_dir/api/." "$api_release/"
cp -R "$extract_dir/ops" "$API_ROOT/"
cp -R "$extract_dir/docs" "$API_ROOT/"
cp "$extract_dir/MANIFEST.json" "$API_ROOT/MANIFEST-$release_name.json"

cat <<EOF
STAGED $release_name

No traffic has been switched.
No services were restarted or reloaded.
No Nginx configuration was changed.

Staged H5 release:
  $h5_release

Staged API release:
  $api_release

When IT approves the cutover, switch deliberately:
  ln -sfn "$h5_release" "$H5_ROOT/current"
  ln -sfn "$api_release" "$API_ROOT/current"

Then configure:
  - systemd WorkingDirectory: $API_ROOT/current
  - Nginx root: $H5_ROOT/current
  - Nginx /api/: http://127.0.0.1:8787/api/

Before cutover:
  cd "$api_release"
  npm install --omit=dev --package-lock=false
  cp "$API_ROOT/ops/aliyun/medical-credit-api.env.example" "$API_ROOT/.env"
  # edit $API_ROOT/.env on the server; never copy it into H5 root
  bash "$API_ROOT/ops/aliyun/preflight-release.sh.example"
EOF
