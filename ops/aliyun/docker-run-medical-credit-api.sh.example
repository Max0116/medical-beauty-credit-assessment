#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   API_ROOT=/www/wwwroot/medical-credit-api \
#   CONTAINER_NAME=medical-credit-api \
#   IMAGE_TAG=medical-credit-assessment-api:pr23 \
#   bash ops/aliyun/docker-run-medical-credit-api.sh.example
#
# Purpose:
# - Build and start only the independent medical-credit API container.
# - Binds the API to 127.0.0.1:8787 so only local Nginx can reach it.
# - Adds host.docker.internal for the case where IT explicitly chooses local MySQL.
# - Does not edit Nginx, H5 files, databases, or other containers.
# - Refuses to replace an existing container with the same name.

API_ROOT="${API_ROOT:-/www/wwwroot/medical-credit-api}"
API_CURRENT="${API_CURRENT:-$API_ROOT/current}"
API_ENV="${API_ENV:-$API_ROOT/.env}"
CONTAINER_NAME="${CONTAINER_NAME:-medical-credit-api}"
IMAGE_TAG="${IMAGE_TAG:-medical-credit-assessment-api:pr23}"
DOCKERFILE="${DOCKERFILE:-$API_ROOT/ops/aliyun/Dockerfile.medical-credit-api}"
HOST_BIND="${MEDICAL_CREDIT_PROXY_HOST:-127.0.0.1}"
PORT="${MEDICAL_CREDIT_PROXY_PORT:-8787}"
HOST_GATEWAY_ALIAS="${MEDICAL_CREDIT_DOCKER_HOST_GATEWAY_ALIAS:-host.docker.internal:host-gateway}"

case "$API_ROOT" in
  /var/www/medical-credit-api|/www/wwwroot/medical-credit-api) ;;
  *)
    echo "Refusing unexpected API_ROOT: $API_ROOT" >&2
    echo "Allowed API_ROOT values: /var/www/medical-credit-api, /www/wwwroot/medical-credit-api" >&2
    exit 1
    ;;
esac

if [[ ! -d "$API_CURRENT" ]]; then
  echo "API_CURRENT does not exist: $API_CURRENT" >&2
  echo "Run stage-release first and switch API_ROOT/current only after IT approves." >&2
  exit 1
fi

if [[ ! -f "$API_ENV" ]]; then
  echo "API_ENV does not exist: $API_ENV" >&2
  echo "Create it from ops/aliyun/medical-credit-api.env.example; never place .env in H5 root." >&2
  exit 1
fi

if [[ ! -f "$DOCKERFILE" ]]; then
  echo "Dockerfile does not exist: $DOCKERFILE" >&2
  exit 1
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required for this runtime path." >&2
  exit 1
fi

if ! docker version >/tmp/medical-credit-docker-run-version.log 2>&1; then
  echo "docker daemon is not reachable." >&2
  sed -n '1,20p' /tmp/medical-credit-docker-run-version.log >&2
  exit 1
fi

if docker ps -a --format '{{.Names}}' | grep -Fxq "$CONTAINER_NAME"; then
  echo "Container already exists: $CONTAINER_NAME" >&2
  echo "This script refuses to replace containers automatically." >&2
  echo "Ask IT to stop/rename the existing medical-credit-api container before rerunning." >&2
  exit 1
fi

if command -v ss >/dev/null 2>&1 && ss -ltn | grep -q ":$PORT "; then
  echo "$HOST_BIND:$PORT appears to be listening already. Inspect before starting the API." >&2
  exit 1
fi

docker build -f "$DOCKERFILE" -t "$IMAGE_TAG" "$API_CURRENT"

docker run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  --env-file "$API_ENV" \
  --add-host "$HOST_GATEWAY_ALIAS" \
  -e MEDICAL_CREDIT_PROXY_HOST=0.0.0.0 \
  -e MEDICAL_CREDIT_PROXY_PORT="$PORT" \
  -e PORT="$PORT" \
  -p "$HOST_BIND:$PORT:$PORT" \
  "$IMAGE_TAG"

sleep 2

if command -v curl >/dev/null 2>&1; then
  curl -fsS "http://$HOST_BIND:$PORT/api/health" || {
    echo "API container started but /api/health did not pass." >&2
    echo "Inspect logs: docker logs $CONTAINER_NAME" >&2
    exit 1
  }
fi

cat <<EOF
STARTED $CONTAINER_NAME

Image:
  $IMAGE_TAG

Local API:
  http://$HOST_BIND:$PORT/api/health

Next manual steps:
  1. Configure Nginx /api/ to proxy to http://$HOST_BIND:$PORT/api/
  2. Run: HEALTH_BASE_URL=<public-origin> npm run health:aliyun
  3. Keep MEDICAL_CREDIT_BACKEND_MODE=dual_write until PR23 smoke passes
  4. If using local MySQL from Docker, set ALIYUN_MYSQL_HOST=host.docker.internal and verify MySQL bind/user host with IT
EOF
