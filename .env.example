# 默认不配置远端地址时，应用使用 localStorage 本地持久化。
# 配置后，前端会通过 assessmentRepository 切换到 Supabase Edge Function 持久化模式。
# 这里只能填写 Supabase publishable / anon key，绝不能填写 service_role / secret key。

VITE_ASSESSMENT_API_URL=https://<project-ref>.supabase.co/functions/v1/assessments
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_ASSESSMENT_API_TIMEOUT_MS=8000
